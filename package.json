{
  "name": "llm-proxy",
  "version": "0.1.0",
  "type": "module",
  "description": "Lightweight LLM proxy gateway with OpenAI/Anthropic compatibility",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:integration:watch": "vitest watch tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "db:migrate": "tsx src/db/migrate.ts",
    "lint": "eslint src tests --ext .ts",
    "docker:build": "docker build -t llm-proxy .",
    "docker:run": "docker run -p 4000:4000 -p 9090:9090 -v $(pwd)/data:/data -v $(pwd)/config.yaml:/config.yaml llm-proxy"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "dockerode": "^4.0.10",
    "express": "^4.21.0",
    "express-prom-bundle": "^7.0.2",
    "js-yaml": "^4.1.0",
    "prom-client": "^15.1.3",
    "undici": "^7.24.6",
    "uuid": "^11.0.2",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@node-rs/argon2": "^2.0.0",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^9.10.0",
    "playwright": "^1.58.2",
    "supertest": "^7.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.1",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
